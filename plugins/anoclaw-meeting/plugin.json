{
  "name": "anoclaw-meeting",
  "displayName": "Meeting",
  "version": "4.0.0",
  "description": "Multi-agent meeting system with LLM orchestration - round-robin/moderator/auto modes, live transcripts, action item extraction, configurable delay, pagination, edit/update",
  "publisher": "anoclaw",
  "main": "extension.js",
  "activationEvents": ["onStartup"],
  "contributes": {
    "tools": [
      { "name": "LaunchMeeting" },
      { "name": "MeetingSearchMemory" },
      { "name": "MeetingReadFile" },
      { "name": "MeetingGetAgents" },
      { "name": "MeetingGetStats" },
      { "name": "MeetingGetPlan" },
      { "name": "MeetingStartPlanSession" },
      { "name": "MeetingWebSearch" },
      { "name": "MeetingWebFetch" }
    ],
    "pages": [{ "id": "meeting", "title": "Meet", "order": 8, "html": "frontend/index.html" }],
    "apiRoutes": [
      { "method": "GET", "path": "/api/v1/meetings" },
      { "method": "POST", "path": "/api/v1/meetings" },
      { "method": "GET", "path": "/api/v1/meetings/:id" },
      { "method": "PUT", "path": "/api/v1/meetings/:id" },
      { "method": "DELETE", "path": "/api/v1/meetings/:id" },
      { "method": "POST", "path": "/api/v1/meetings/:id/start" },
      { "method": "POST", "path": "/api/v1/meetings/:id/stop" },
      { "method": "POST", "path": "/api/v1/meetings/:id/action-status" },
      { "method": "GET", "path": "/api/v1/meetings/:id/analytics" },
      { "method": "GET", "path": "/api/v1/meetings/:id/plan" },
      { "method": "POST", "path": "/api/v1/meetings/:id/plan/session" },
      { "method": "POST", "path": "/api/v1/meetings/compare" },
      { "method": "GET", "path": "/api/v1/meetings/recurring-patterns" },
      { "method": "GET", "path": "/api/v1/meetings/roles" },
      { "method": "GET", "path": "/api/v1/meetings/action-statuses" },
      { "method": "GET", "path": "/api/v1/plugins/meeting/agents" },
      { "method": "GET", "path": "/api/v1/plugins/meeting/diagnose/llm" },
      { "method": "GET", "path": "/api/v1/meetings/seq" },
      { "method": "GET", "path": "/api/v1/meetings/templates" },
      { "method": "GET", "path": "/api/v1/meetings/search" },
      { "method": "GET", "path": "/api/v1/meetings/:id/export" }
    ]
  },
  "engines": { "anoclaw": ">=2.1.0" }
}

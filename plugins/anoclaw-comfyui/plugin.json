{
  "name": "anoclaw-comfyui",
  "displayName": "ComfyUI",
  "version": "3.0.0",
  "description": "ComfyUI image generation integration - inspect workflows, generate images (txt2img/img2img), check dependencies, download from GitHub, manage ComfyUI process, WebSocket real-time progress, output gallery, visual frontend",
  "publisher": "anoclaw",
  "main": "extension.js",
  "activationEvents": ["onStartup"],
  "contributes": {
    "tools": [
      { "name": "Comfy" },
      { "name": "comfyGenerateAsset" },
      { "name": "comfySubmitJob" },
      { "name": "comfyGetJobStatus" },
      { "name": "comfyCancelJob" },
      { "name": "comfyEnhancePrompt" },
      { "name": "comfyListWorkflows" },
      { "name": "comfyImportWorkflow" },
      { "name": "comfyDiscoverGithubWorkflows" },
      { "name": "comfyImportGithubWorkflows" },
      { "name": "comfyListWorkflowSources" },
      { "name": "comfyDiscoverCommunityWorkflows" },
      { "name": "comfyImportCommunityWorkflows" },
      { "name": "comfyValidateWorkflow" },
      { "name": "comfyListOutputs" },
      { "name": "comfyListModels" },
      { "name": "comfyDownloadModel" },
      { "name": "comfyListJobs" },
      { "name": "comfyTagDataset" },
      { "name": "comfyPrepareTrainingJob" },
      { "name": "comfyListTrainingJobs" },
      { "name": "comfyStartTrainingJob" },
      { "name": "comfyGetTrainingJobStatus" },
      { "name": "comfyStopTrainingJob" },
      { "name": "comfyVersionStatus" },
      { "name": "comfyManageVersion" },
      { "name": "startComfyUI" },
      { "name": "stopComfyUI" },
      { "name": "getComfyUIStatus" },
      { "name": "getQueueStatus" }
    ],
    "pages": [
      { "id": "comfyui", "title": "ComfyUI", "html": "frontend/index.html", "order": 7 }
    ],
    "apiRoutes": [
      { "method": "GET", "path": "/api/v1/plugins/comfyui/image" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/process/start" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/process/stop" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/process/status" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/process/logs" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/gallery" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/asset-data" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/workflows" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/workflows/import" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/workflows/github/discover" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/workflows/github/import" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/workflows/sources" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/workflows/community/discover" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/workflows/community/import" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/workflows/validate" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/models" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/models/download" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/outputs" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/jobs" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/jobs/submit" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/jobs/status" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/jobs/cancel" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/prompt/enhance" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/tag-dataset" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/training/prepare" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/training/jobs" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/training/start" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/training/status" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/training/stop" },
      { "method": "GET", "path": "/api/v1/plugins/comfyui/version" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/version/manage" },
      { "method": "POST", "path": "/api/v1/plugins/comfyui/upload" }
    ],
    "configuration": {
      "title": "ComfyUI Settings",
      "properties": {
        "serverUrl": { "type": "string", "default": "http://127.0.0.1:8188", "description": "ComfyUI server URL" },
        "pythonPath": { "type": "string", "default": "C:/Users/Administrator/AppData/Local/Programs/Python/Python312/python.exe", "description": "Python executable path" },
        "comfyDir": { "type": "string", "default": "", "description": "ComfyUI directory. Leave empty to auto-detect." },
        "timeout": { "type": "number", "default": 300, "description": "Generation timeout in seconds" }
      }
    }
  },
  "engines": { "anoclaw": ">=2.1.0" }
}

{
  "name": "anoclaw-pdf",
  "displayName": "PDF",
  "version": "0.1.0",
  "description": "Official AnoClaw PDF artifact tools for extracting and summarizing PDF documents.",
  "publisher": "anoclaw",
  "main": "extension.js",
  "activationEvents": ["onStartup"],
  "engines": {
    "anoclaw": "^2.0.0"
  },
  "contributes": {
    "tools": [
      { "name": "pdf.summarize" }
    ],
    "capabilities": [
      {
        "id": "pdf.summarize",
        "title": "Summarize a PDF",
        "description": "Extract text from a PDF and generate a markdown summary artifact with page notes.",
        "domain": "pdf",
        "kind": "analysis",
        "triggers": ["pdf", "summarize pdf", "extract pdf", "PDF总结", "总结PDF", "阅读PDF", "PDF摘要"],
        "examples": [
          "把这个PDF总结成一页报告",
          "Summarize this PDF and extract the key points"
        ],
        "inputs": [
          { "name": "filePath", "label": "PDF file", "type": "file", "required": false, "aliases": ["文件", "pdf", "路径"] },
          { "name": "pages", "label": "Pages", "type": "string", "required": false, "aliases": ["页码", "范围"] },
          { "name": "title", "label": "Title", "type": "string", "required": false, "defaultValue": "PDF summary", "aliases": ["标题", "主题"] }
        ],
        "outputs": [
          { "type": "file", "label": "Markdown summary", "mimeType": "text/markdown", "extension": "md", "artifactType": "document" },
          { "type": "preview", "label": "Summary preview", "mimeType": "text/markdown", "artifactType": "pdf" }
        ],
        "requiredTools": ["pdf.summarize"],
        "artifactTypes": ["pdf", "document", "report"],
        "recommendedPlugins": ["anoclaw-pdf"],
        "priority": 92
      }
    ]
  }
}
